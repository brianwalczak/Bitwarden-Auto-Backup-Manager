{
    "name": "bitwarden-auto-backup-manager",
    "productName": "Bitwarden Auto-Backup Manager",
    "description": "A robust application that creates local, encrypted auto-backups for your Bitwarden vault.",
    "author": {
        "name": "Brian Walczak",
        "email": "me@brian.re"
    },
    "version": "2.2.2",
    "main": "main/index.js",
    "type": "module",
    "scripts": {
        "start": "electron .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.brianwalczak.bitwarden-auto-backup-manager",
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ]
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "universal"
                    ]
                }
            ],
            "category": "public.app-category.utilities"
        },
        "linux": {
            "target": [
                {
                    "target": "deb",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "rpm",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "category": "Utility"
        },
        "publish": null,
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": false,
            "perMachine": false
        },
        "extraResources": [
            {
                "from": "build/icon.png",
                "to": "icon.png"
            }
        ]
    },
    "dependencies": {
        "@bitwarden/sdk-internal": "0.2.0-main.546",
        "big-integer": "1.6.52",
        "compare-versions": "^6.1.1",
        "electron-log": "^5.4.3",
        "keytar": "^7.9.0",
        "rxjs": "7.8.1",
        "tldts": "7.0.22"
    },
    "devDependencies": {
        "@electron-toolkit/eslint-config": "^2.1.0",
        "electron": "^40.4.1",
        "electron-builder": "^26.8.1",
        "eslint": "^10.0.0",
        "prettier": "^3.8.1"
    }
}
